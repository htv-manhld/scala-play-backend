# Analytics Service Environment Variables Example
APPLICATION_SECRET=your-application-secret-key-min-64-chars

# Database Configuration
DB_DEFAULT_URL=jdbc:postgresql://postgres:5432/microservicesdb
DB_DEFAULT_USERNAME=postgres
DB_DEFAULT_PASSWORD=password

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_USER_EVENTS=user-domain-events
KAFKA_TOPIC_ANALYTICS_EVENTS=analytics-events

# InfluxDB Configuration (for time series data)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=analytics
INFLUXDB_BUCKET=metrics

# Service Discovery
CONSUL_HOST=consul
CONSUL_PORT=8500

# Service Info
SERVICE_NAME=analytics-service
SERVICE_VERSION=1.0.0
SERVICE_HOST=analytics-service
SERVICE_PORT=9003

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG_MODE=true

# Database Pool Settings
DB_MAX_CONNECTIONS=5
DB_MIN_CONNECTIONS=1
DB_CONNECTION_TIMEOUT=30000

# Analytics Settings
METRICS_RETENTION_DAYS=30
BATCH_SIZE=1000
PROCESSING_INTERVAL_SECONDS=60